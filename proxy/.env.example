# Copy these into the Vercel dashboard (Project → Settings → Environment
# Variables), then redeploy. Never commit real values.

# --- Credibility (Stage-3) --------------------------------------------------
# Required for /api/credibility. Google AI Studio key for Gemini.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# --- Detection (Stage-2) ----------------------------------------------------
# The first configured provider wins: Pangram > Hugging Face > Gemini estimate.
# With only GEMINI_API_KEY set, /api/detect falls back to a Gemini heuristic.
# HF_TOKEN=                 # Hugging Face access token (read scope) — free open detector
# HF_DETECT_MODEL=fakespot-ai/roberta-base-ai-text-detection-v1
# PANGRAM_API_KEY=          # paid, strongest accuracy
# PANGRAM_ENDPOINT=https://text.api.pangram.com/v1/predict

# --- CORS -------------------------------------------------------------------
# chrome-extension:// and moz-extension:// origins are always allowed.
# Add extra web origins (comma-separated) here, or "*" for open testing.
# ALLOWED_ORIGINS=

# --- Cache + rate limit store (recommended for production) ------------------
# Upstash Redis REST (or Vercel KV). Without these, cache/limits are per-instance
# in-memory and reset on cold starts.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Tuning (optional) ------------------------------------------------------
# RATE_LIMIT_DETECT=60          # requests/min/IP
# RATE_LIMIT_CREDIBILITY=15     # requests/min/IP
# CACHE_TTL_DETECT=86400        # seconds
# CACHE_TTL_CREDIBILITY=21600   # seconds
